{
  "expo": {
    "name": "Stampworth Business",
    "slug": "businessapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/stampworthb-logo.png",
    "scheme": "stampworthbusiness",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow $(PRODUCT_NAME) to use your location to set up geofencing for location-based promotions."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyC2VkT6Kj7MY1W2ilwIjXevs5cTYJU7OXIc"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ],
      "package": "com.anonymous.stampworthbusiness",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyC2VkT6Kj7MY1W2ilwIjXevs5cTYJU7OXIc"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/stampworthb-logo.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to set up geofencing for location-based promotions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "940f316d-94bb-46b7-9642-a3ec95d0d79d"
      }
    }
  }
}
