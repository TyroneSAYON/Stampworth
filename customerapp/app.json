{
  "expo": {
    "name": "Stampworth",
    "slug": "stampworth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/stampworth-logo.png",
    "scheme": "stampworth",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show nearby merchants and provide navigation.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses your location to show nearby merchants and provide navigation."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyAZyqmXzl9ZD3ItUQ0EJDfq4GFqz_kkWIE"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/stampworth-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.stampworth",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAZyqmXzl9ZD3ItUQ0EJDfq4GFqz_kkWIE"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/stampworth-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to show nearby merchants."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3c8606be-d5a8-423c-9c31-e765ce3e7f4c"
      }
    }
  }
}
